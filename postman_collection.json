    {
      "name": "3. Register New Student to Course",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"matricNumber\": \"E776\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Dougherty\",\n  \"dateOfAdmission\": \"2026-06-15\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/students/register?courseId=3",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "students",
            "register"
          ],
          "query": [
            {
              "key": "courseId",
              "value": "3"
            }
          ]
        }
      },
      "response": []
    }
  ]
